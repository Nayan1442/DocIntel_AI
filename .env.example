# ── App ──────────────────────────────────────────
APP_NAME=AI Document Intelligence Platform
DEBUG=true

# ── MongoDB ──────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=doc_intelligence

# ── LLM Provider ────────────────────────────────
# Options: "groq" or "openrouter"
LLM_PROVIDER=openrouter

# Leave LLM_MODEL empty to use the provider's default model
# Groq default: llama-3.3-70b-versatile
# OpenRouter default: meta-llama/llama-3.3-70b-instruct
LLM_MODEL=

# ── API Keys (set the one matching your provider) ─
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Embedding ───────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Upload ──────────────────────────────────────
MAX_FILE_SIZE_MB=50
